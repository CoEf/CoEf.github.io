---
import { CATEGORIES, type Category } from '../utils/categories';

interface Props {
  href: string;
  title: string;
  date: Date;
  summary: string;
  tags: string[];
  category: Category;
  latest?: boolean;
}

const { href, title, date, summary, tags, category, latest = false } = Astro.props;
const meta = CATEGORIES[category];
const formatted = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---
<div class:list={['signal-node', { latest }]}>
  <a href={href} class="entry">
    <div class="entry-top">
      <span class="date mono">{formatted}</span>
      <span
        class="category-badge"
        style={`--dot-color: var(${meta.colorVar}); --dot-dim: var(${meta.dimVar});`}
      >
        <span class="dot"></span>
        {meta.label}
      </span>
    </div>
    <h3>{title}</h3>
    <p class="summary">{summary}</p>
    <div class="tags">
      {tags.map((t) => <span class="tag">#{t}</span>)}
    </div>
  </a>
</div>

<style>
  .entry {
    display: block;
  }

  .entry-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .date {
    font-size: 12px;
    color: var(--signal);
    letter-spacing: 0.04em;
  }

  h3 {
    font-size: 1.05rem;
    margin: 6px 0 6px;
    color: var(--text);
  }

  .entry:hover h3 {
    color: var(--signal);
  }

  .summary {
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 10px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
  }
</style>

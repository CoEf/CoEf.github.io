---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../utils/paths';

interface Props {
  title: string;
  status: 'in-progress' | 'completed' | 'archived';
  stack: string[];
  role?: string;
  startDate: Date;
  links?: { repo?: string; demo?: string };
}

const { title, status, stack, role, startDate, links } = Astro.props;

const statusLabel = {
  'in-progress': '진행중',
  completed: '완료',
  archived: '보관',
};

const formatted = startDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: '2-digit',
});
---
<BaseLayout title={title}>
  <article class="post">
    <a href={withBase('projects/')} class="back mono">← Projects 목록</a>

    <div class="node-label">
      <span class="dot"></span>
      PROJECT_NODE
    </div>

    <div class="title-row">
      <h1>{title}</h1>
      <span class:list={['status-badge', status]}>{statusLabel[status]}</span>
    </div>

    <div class="meta mono">
      <span>시작 {formatted}</span>
      {role && <span>· {role}</span>}
    </div>

    <div class="stack">
      {stack.map((s) => <span class="tag">{s}</span>)}
    </div>

    {links && (links.repo || links.demo) && (
      <div class="links mono">
        {links.repo && <a href={links.repo} target="_blank" rel="noreferrer">Repo ↗</a>}
        {links.demo && <a href={links.demo} target="_blank" rel="noreferrer">Demo ↗</a>}
      </div>
    )}

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: 40px 0 60px;
  }

  .back {
    display: inline-block;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 24px;
  }

  .back:hover {
    color: var(--signal);
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin: 14px 0 10px;
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2.1rem);
  }

  .meta {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 14px;
  }

  .stack {
    margin-bottom: 6px;
  }

  .links {
    display: flex;
    gap: 16px;
    font-size: 13px;
    margin-bottom: 10px;
  }

  .links a {
    color: var(--signal);
  }

  .prose {
    border-top: 1px solid var(--line);
    margin-top: 24px;
    padding-top: 30px;
  }

  .prose :global(h2) {
    font-size: 1.3rem;
    margin: 2.2em 0 0.7em;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    margin: 1.8em 0 0.6em;
  }

  .prose :global(p) {
    margin: 0 0 1.1em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.1em;
    padding-left: 1.3em;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }

  .prose :global(a) {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(pre) {
    margin: 1.4em 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.4em auto;
    border-radius: var(--radius);
  }

  /* image caption: a paragraph whose only content is a single *em* run */
  .prose :global(p:has(> em:only-child)) {
    text-align: center;
    font-size: 13px;
    color: var(--muted);
    margin-top: -1em;
    margin-bottom: 1.4em;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.6em 0;
    font-size: 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .prose :global(thead) {
    background: var(--surface);
  }

  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--signal);
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
  }

  .prose :global(td) {
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
    color: var(--text);
    vertical-align: top;
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(tbody tr:hover) {
    background: var(--surface-hover);
  }

  .prose :global(table code) {
    white-space: nowrap;
  }

  /* tree diagram — see /src/content/blog/devlog/_tree-diagram-example.md */
  .prose :global(.tree) {
    margin: 1.6em 0;
  }

  .prose :global(.tree-root) {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 12px 16px;
    margin-bottom: 14px;
  }

  .prose :global(.tree-root-name) {
    font-weight: 600;
    color: var(--text);
  }

  .prose :global(.tree-root-name em) {
    font-style: normal;
    font-weight: 400;
    color: var(--muted);
  }

  .prose :global(.tree-root-file) {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8em;
    color: var(--signal);
    margin-top: 4px;
  }

  .prose :global(.tree ul) {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .prose :global(.tree ul ul) {
    margin-left: 22px;
  }

  .prose :global(.tree li) {
    position: relative;
    padding: 7px 0 7px 22px;
    margin-bottom: 0;
  }

  .prose :global(.tree li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    border-left: 1px solid var(--line);
  }

  .prose :global(.tree li:last-child::before) {
    bottom: auto;
    height: 15px;
  }

  .prose :global(.tree li::after) {
    content: '';
    position: absolute;
    left: 0;
    top: 15px;
    width: 15px;
    height: 0;
    border-top: 1px solid var(--line);
  }

  .prose :global(.tree-node) {
    font-weight: 600;
    font-size: 0.92em;
    color: var(--text);
    margin-right: 6px;
  }

  .prose :global(.tree-desc) {
    font-size: 0.8em;
    color: var(--muted);
    margin-left: 6px;
  }

  @media (max-width: 640px) {
    .prose :global(table) {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }
  }</style>

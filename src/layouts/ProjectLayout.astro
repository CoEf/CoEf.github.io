---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../utils/paths';

interface Props {
  title: string;
  status: 'in-progress' | 'completed' | 'archived';
  stack: string[];
  role?: string;
  startDate: Date;
  links?: { repo?: string; demo?: string };
}

const { title, status, stack, role, startDate, links } = Astro.props;

const statusLabel = {
  'in-progress': '진행중',
  completed: '완료',
  archived: '보관',
};

const formatted = startDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: '2-digit',
});
---
<BaseLayout title={title}>
  <article class="post">
    <a href={withBase('projects/')} class="back mono">← Projects 목록</a>

    <div class="node-label">
      <span class="dot"></span>
      PROJECT_NODE
    </div>

    <div class="title-row">
      <h1>{title}</h1>
      <span class:list={['status-badge', status]}>{statusLabel[status]}</span>
    </div>

    <div class="meta mono">
      <span>시작 {formatted}</span>
      {role && <span>· {role}</span>}
    </div>

    <div class="stack">
      {stack.map((s) => <span class="tag">{s}</span>)}
    </div>

    {links && (links.repo || links.demo) && (
      <div class="links mono">
        {links.repo && <a href={links.repo} target="_blank" rel="noreferrer">Repo ↗</a>}
        {links.demo && <a href={links.demo} target="_blank" rel="noreferrer">Demo ↗</a>}
      </div>
    )}

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: 40px 0 60px;
  }

  .back {
    display: inline-block;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 24px;
  }

  .back:hover {
    color: var(--signal);
  }

  .title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin: 14px 0 10px;
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2.1rem);
  }

  .meta {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 14px;
  }

  .stack {
    margin-bottom: 6px;
  }

  .links {
    display: flex;
    gap: 16px;
    font-size: 13px;
    margin-bottom: 10px;
  }

  .links a {
    color: var(--signal);
  }

  .prose {
    border-top: 1px solid var(--line);
    margin-top: 24px;
    padding-top: 30px;
  }

  .prose :global(h2) {
    font-size: 1.3rem;
    margin: 2.2em 0 0.7em;
  }

  .prose :global(h3) {
    font-size: 1.1rem;
    margin: 1.8em 0 0.6em;
  }

  .prose :global(p) {
    margin: 0 0 1.1em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.1em;
    padding-left: 1.3em;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }

  .prose :global(a) {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(pre) {
    margin: 1.4em 0;
  }
</style>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DevlogEntry from '../../../components/DevlogEntry.astro';
import { withBase } from '../../../utils/paths';
import { CATEGORIES, CATEGORY_LIST, type Category } from '../../../utils/categories';

export async function getStaticPaths() {
  return CATEGORY_LIST.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params as { category: Category };
const meta = CATEGORIES[category];

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === category))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={`Devlog · ${meta.label}`} description={`${meta.label} 관련 글 목록`}>
  <section class="page">
    <div
      class="node-label"
      style={`--dot-color: var(${meta.colorVar}); --dot-dim: var(${meta.dimVar});`}
    >
      <span class="dot"></span>
      {meta.label.toUpperCase()}
    </div>
    <h1>{meta.label}</h1>
    <p class="sub">{meta.label} 카테고리의 글 {posts.length}개</p>

    <nav class="category-tabs">
      <a href={withBase('blog/')} class="category-tab">전체</a>
      {CATEGORY_LIST.map((c) => (
        <a
          href={withBase(`blog/category/${c}/`)}
          class:list={['category-tab', { active: c === category }]}
          style={`--dot-color: var(${CATEGORIES[c].colorVar}); --dot-dim: var(${CATEGORIES[c].dimVar});`}
        >
          <span class="dot"></span>
          {CATEGORIES[c].label}
        </a>
      ))}
    </nav>

    <div class="signal-line list">
      {posts.map((post, i) => (
        <DevlogEntry
          href={withBase(`blog/${post.slug}/`)}
          title={post.data.title}
          date={post.data.date}
          summary={post.data.summary}
          tags={post.data.tags}
          category={post.data.category}
          latest={i === 0}
        />
      ))}
    </div>

    {posts.length === 0 && <p class="empty mono">아직 이 카테고리에 작성된 글이 없습니다.</p>}
  </section>
</BaseLayout>

<style>
  .page {
    padding: 44px 0 60px;
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2rem);
    margin: 14px 0 8px;
  }

  .sub {
    color: var(--muted);
    font-size: 14.5px;
    margin: 0 0 24px;
  }

  .empty {
    color: var(--muted);
    font-size: 13px;
  }
</style>

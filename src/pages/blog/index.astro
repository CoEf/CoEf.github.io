---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DevlogEntry from '../../components/DevlogEntry.astro';
import { withBase } from '../../utils/paths';
import { CATEGORIES, CATEGORY_LIST } from '../../utils/categories';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Devlog" description="개발 기록 전체 목록">
  <section class="page">
    <div class="node-label warn">
      <span class="dot"></span>
      DEVLOG
    </div>
    <h1>개발 기록</h1>
    <p class="sub">진행 중인 작업, 아키텍처 노트, 트러블슈팅을 시간순으로 남깁니다.</p>

    <nav class="category-tabs">
      <a href={withBase('blog/')} class="category-tab active">전체</a>
      {CATEGORY_LIST.map((c) => (
        <a
          href={withBase(`blog/category/${c}/`)}
          class="category-tab"
          style={`--dot-color: var(${CATEGORIES[c].colorVar}); --dot-dim: var(${CATEGORIES[c].dimVar});`}
        >
          <span class="dot"></span>
          {CATEGORIES[c].label}
        </a>
      ))}
    </nav>

    <div class="signal-line list">
      {posts.map((post, i) => (
        <DevlogEntry
          href={withBase(`blog/${post.slug}/`)}
          title={post.data.title}
          date={post.data.date}
          summary={post.data.summary}
          tags={post.data.tags}
          category={post.data.category}
          latest={i === 0}
        />
      ))}
    </div>

    {posts.length === 0 && <p class="empty mono">아직 작성된 글이 없습니다.</p>}
  </section>
</BaseLayout>

<style>
  .page {
    padding: 44px 0 60px;
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2rem);
    margin: 14px 0 8px;
  }

  .sub {
    color: var(--muted);
    font-size: 14.5px;
    margin: 0 0 40px;
  }

  .empty {
    color: var(--muted);
    font-size: 13px;
  }
</style>

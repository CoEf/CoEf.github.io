---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import DevlogEntry from '../components/DevlogEntry.astro';
import { withBase } from '../utils/paths';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<BaseLayout title="Home">
  <section class="hero">
    <svg class="graph" viewBox="0 0 340 90" fill="none" aria-hidden="true">
      <path d="M20 45 H120" stroke="#2a2e3a" stroke-width="1.5" />
      <path d="M120 45 H170 M120 45 V15 H220 M120 45 V75 H220" stroke="#2a2e3a" stroke-width="1.5" />
      <path d="M220 15 H310 M220 75 H310" stroke="#2a2e3a" stroke-width="1.5" />
      <circle cx="20" cy="45" r="5" fill="#12141a" stroke="#6fe7c8" stroke-width="2" />
      <circle cx="120" cy="45" r="5" fill="#12141a" stroke="#6fe7c8" stroke-width="2" />
      <circle cx="220" cy="15" r="5" fill="#12141a" stroke="#f2a65a" stroke-width="2" />
      <circle cx="220" cy="75" r="5" fill="#12141a" stroke="#6fe7c8" stroke-width="2" />
      <circle cx="310" cy="15" r="4" fill="#2a2e3a" />
      <circle cx="310" cy="75" r="4" fill="#2a2e3a" />
    </svg>

    <div class="node-label">
      <span class="dot"></span>
      PORTFOLIO_NODE
    </div>
    <h1>신 — Godot 게임 클라이언트 프로그래머</h1>
    <p class="lede">
      컴포넌트가 API를 제공하고 컨트롤러가 오케스트레이션을 담당하는
      구조로 게임 시스템을 설계합니다. 인벤토리, 무기, 드래그앤드롭 UI 등을
      Godot 4 / GDScript로 구현한 기록을 여기에 남깁니다.
    </p>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="node-label">
        <span class="dot"></span>
        PROJECTS
      </div>
      <a href={withBase('projects/')} class="see-all mono">전체 보기 →</a>
    </div>
    <div class="project-grid">
      {projects.map((p) => (
        <ProjectCard
          href={withBase(`projects/${p.slug}/`)}
          title={p.data.title}
          summary={p.data.summary}
          status={p.data.status}
          stack={p.data.stack}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="node-label warn">
        <span class="dot"></span>
        DEVLOG
      </div>
      <a href={withBase('blog/')} class="see-all mono">전체 보기 →</a>
    </div>
    <div class="signal-line">
      {posts.map((post, i) => (
        <DevlogEntry
          href={withBase(`blog/${post.slug}/`)}
          title={post.data.title}
          date={post.data.date}
          summary={post.data.summary}
          tags={post.data.tags}
          category={post.data.category}
          latest={i === 0}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 56px 0 40px;
    position: relative;
  }

  .graph {
    width: 100%;
    max-width: 340px;
    height: auto;
    margin-bottom: 20px;
  }

  h1 {
    font-size: clamp(1.7rem, 4.4vw, 2.3rem);
    margin: 14px 0 16px;
    max-width: 20ch;
  }

  .lede {
    color: var(--muted);
    font-size: 15.5px;
    line-height: 1.75;
    max-width: 52ch;
    margin: 0;
  }

  .section {
    padding: 44px 0;
    border-top: 1px solid var(--line);
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 22px;
  }

  .see-all {
    font-size: 12.5px;
    color: var(--muted);
  }

  .see-all:hover {
    color: var(--signal);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin: 0 -6px;
  }
</style>
